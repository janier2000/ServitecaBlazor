@if (vehicleTypeENT is null)
{
    <Loading />
}
else
{
    <MudDialog>
        <DialogContent>
            <VehicleTypesForm @ref="vehicleTypesForm"
                               VehicleTypeENT="vehicleTypeENT"
                               OnValidSubmit="EditAsync"
                               ReturnAction="Return" />
        </DialogContent>
    </MudDialog>
}