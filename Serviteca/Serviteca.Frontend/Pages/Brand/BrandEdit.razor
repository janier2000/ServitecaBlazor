@page "/Brand/edit/{Id:int}"

@if (vehicleBrandENT is null)
{
    <Loading/>
}
else
{
    <FormWithName @ref="vehicleBrandFORM"
                  Label="Nombre"
                  Featured="Edidar marca"
                  Model="vehicleBrandENT"
                  OnValidSubmit="EditAsync"
                  ReturnAction="Return" />

}