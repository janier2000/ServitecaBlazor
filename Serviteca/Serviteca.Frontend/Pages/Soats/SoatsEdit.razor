@if (soatDtoENT is null)
{
    <Loading />
}
else
{
    <MudDialog>
        <DialogContent>
            <SoatsForm @ref="soatsForm"
                       SoatDtoENT="soatDtoENT"
                          OnValidSubmit="EditAsync"
                          ReturnAction="Return" />
        </DialogContent>
    </MudDialog>
}