<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation" />

<MudContainer Style="max-height: 400px; overflow-y: scroll" Class="m-0 p-0">
   
    <EditForm EditContext="editContext" OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit">
        <MudGrid>

            <DataAnnotationsValidator />

            <MudItem xs="12" sm="12">
                <MudAutocomplete Label="Buscar cliente"
                                 T="Customer"
                                 Value="selectedCustomer"
                                 SearchFunc="SearchCustomer"
                                 ValueChanged="ChangedCustomer"
                                 Placeholder="Buscar  cliente"
                                 ResetValueOnEmptyText="true"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 AdornmentColor="Color.Primary"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 ToStringFunc="@(e => e.FirstName == "" || e.FirstName == null || e.FirstName == string.Empty ? null : $"{e.Document} - {e.FirstName} {e.LastName}")">
                    <ItemTemplate Context="itemContext">
                        @itemContext.Document -  @itemContext.FirstName @itemContext.LastName 
                    </ItemTemplate>
                </MudAutocomplete>

            </MudItem>

            <MudItem xs="6" sm="6">
                <MudDatePicker Label="Retorno cliente"
                               Date="selectedReturnDate"
                               DateChanged="ChangedReturnDate"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               DateFormat="dd/MM/yyyy"
                               Class="mb-2" />


                <MudAutocomplete Label="Marca"
                                 T="Brand"
                                 Value="selectedBrand"
                                 SearchFunc="SearchBrand"
                                 ValueChanged="ChangedBrand"
                                 Placeholder="-- Seleccione  marca --"
                                 ToStringFunc="@(e=> e==null?null : $"{e.Name}")"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Class="mb-2">
                    <ItemTemplate Context="itemContext">
                        @itemContext.Name
                    </ItemTemplate>
                </MudAutocomplete>


                <MudAutocomplete Label="Tipo"
                                 T="TypeV"
                                 Value="selectedType"
                                 SearchFunc="SearchType"
                                 ValueChanged="ChangedType"
                                 Placeholder="-- Seleccione  tipo --"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 ToStringFunc="@(e=> e==null?null : $"{e.Name}")"
                                 Class="mb-2">
                    <ItemTemplate Context="itemContext">
                        @itemContext.Name
                    </ItemTemplate>
                </MudAutocomplete>

                <MudTextField Label="Modelo"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="@VehicleDtoENT.Model"
                              For="@(() => VehicleDtoENT.Model)"
                              Class="mb-4" />

            </MudItem>

            <MudItem xs="6" sm="6">
             

                <MudTextField Label="Placa"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="@VehicleDtoENT.Plate"
                              For="@(() => VehicleDtoENT.Plate)"
                              Class="mb-4" />

                <MudAutocomplete Label="Uso"
                                 T="Use"
                                 Value="selectedUse"
                                 SearchFunc="SearchUse"
                                 ValueChanged="ChangedUse"
                                 Placeholder="-- Seleccione  uso --"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 ToStringFunc="@(e=> e==null?null : $"{e.Name}")"
                                 Class="mb-2" />

                <MudTextField Label="Kilometraje actual"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="@VehicleDtoENT.CurrentKm"
                              For="@(() => VehicleDtoENT.CurrentKm)"
                              Class="mb-4" />

            </MudItem>

            <MudItem xs="12" sm="12">

                <MudButton Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Color="Color.Error"
                           OnClick="ReturnAction">
                    Regresar
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.Save"
                           Color="Color.Info"
                           ButtonType="ButtonType.Submit">
                    @accion
                </MudButton>

            </MudItem>

        </MudGrid>
    </EditForm>

</MudContainer>
