<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation" />

<MudContainer Style="max-height: 400px; overflow-y: scroll" Class="m-0 p-0">
   
    <EditForm EditContext="editContext" OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit">
        <MudGrid>
            <DataAnnotationsValidator />

            <MudItem xs="12" sm="12">
                <MudAutocomplete Label="Buscar cliente" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" AdornmentColor="Color.Primary"
                                 T="Customer"
                                 Value="selectedCustomer"
                                 SearchFunc="SearchCustomer"
                                 ValueChanged="ChangedCustomer"
                                 Placeholder="Buscar  cliente"
                                 ResetValueOnEmptyText="true"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 ToStringFunc="@(e => e.FirstName == "" || e.FirstName == null || e.FirstName == string.Empty ? null : $"{e.Document} - {e.FirstName} {e.LastName}")">
                    <ItemTemplate Context="itemContext">
                        @itemContext.Document -  @itemContext.FirstName @itemContext.LastName
                    </ItemTemplate>
                </MudAutocomplete>
            </MudItem>

            <MudItem xs="6" sm="6">

                <MudDatePicker Label="Retorno cliente" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                               Date="selectedReturnDate"
                               DateChanged="ChangedReturnDate"
                               DateFormat="dd/MM/yyyy">
                </MudDatePicker>


                <MudAutocomplete Label="Marca" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                 T="Brand"
                                 Value="selectedBrand"
                                 SearchFunc="SearchBrand"
                                 ValueChanged="ChangedBrand"
                                 Placeholder="-- Seleccione  marca --"
                                 ToStringFunc="@(e=> e==null?null : $"{e.Name}")">
                    <ItemTemplate Context="itemContext">
                        @itemContext.Name
                    </ItemTemplate>
                </MudAutocomplete>

                <MudAutocomplete Label="Tipo" Variant="Variant.Outlined" Margin="Margin.Dense"  Class="mb-2"
                                 T="TypeV"
                                 Value="selectedType"
                                 SearchFunc="SearchType"
                                 ValueChanged="ChangedType"
                                 Placeholder="-- Seleccione  tipo --"
                                 ToStringFunc="@(e=> e==null?null : $"{e.Name}")">
                    <ItemTemplate Context="itemContext">
                        @itemContext.Name
                    </ItemTemplate>
                </MudAutocomplete>

                <MudTextField Label="Modelo" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              @bind-Value="@VehicleDtoENT.Model"
                              For="@(() => VehicleDtoENT.Model)">
                </MudTextField>

            </MudItem>

            <MudItem xs="6" sm="6">
             
                <MudTextField Label="Placa" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              @bind-Value="@VehicleDtoENT.Plate"
                              For="@(() => VehicleDtoENT.Plate)">
                </MudTextField>

                <MudAutocomplete Label="Uso" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                 T="Use"
                                 Value="selectedUse"
                                 SearchFunc="SearchUse"
                                 ValueChanged="ChangedUse"
                                 Placeholder="-- Seleccione  uso --"
                                 ToStringFunc="@(e=> e==null?null : $"{e.Name}")">
                </MudAutocomplete>

                <MudTextField Label="Kilometraje actual" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              @bind-Value="@VehicleDtoENT.CurrentKm"
                              For="@(() => VehicleDtoENT.CurrentKm)">
                </MudTextField>

            </MudItem>
        </MudGrid>

        <MudGrid>
            <MudItem xs="9" Class="d-flex justify-end">

                <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="ReturnAction">
                    Regresar
                </MudButton>

                <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Save"
                           ButtonType="ButtonType.Submit">
                    @accion
                </MudButton>

            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>
