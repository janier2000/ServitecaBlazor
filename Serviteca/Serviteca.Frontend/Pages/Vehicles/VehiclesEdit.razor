@if (vehicleDtoENT is null)
{
    <Loading />
}
else
{
    <MudDialog>
        <DialogContent>
            <VehiclesForm @ref="vehiclesForm"
                          VehicleDtoENT="vehicleDtoENT"
                          OnValidSubmit="EditAsync"
                          ReturnAction="Return" />
        </DialogContent>
    </MudDialog>
}