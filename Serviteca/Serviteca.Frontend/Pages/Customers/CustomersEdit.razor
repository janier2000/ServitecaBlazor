@if (customerDtoENT is null)
{
    <Loading />
}
else
{
    <MudDialog>
        <DialogContent>
            <CustomersForm @ref="customersForm"
                           CustomerDtoENT="customerDtoENT"
                           OnValidSubmit="EditAsync"
                           ReturnAction="Return" />
        </DialogContent>
    </MudDialog>
}