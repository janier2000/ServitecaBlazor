<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation" />

@* <MudContainer Style="max-height: 400px; overflow-y: scroll" Class="m-0 p-0"> *@
<MudContainer Style="max-height: 400px; overflow-y: scroll" Class="m-0 p-0">
    <EditForm EditContext="editContext" OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit">
        <MudGrid>

            <DataAnnotationsValidator />

            <MudItem xs="6" sm="6">

                <MudDatePicker Label="Cliente desde" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                               Date="selectedDate"
                               Disabled="@DisabledDate"
                               DateChanged="OnDateChanged"
                               DateFormat="dd/MM/yyyy">
                </MudDatePicker>

                <MudAutocomplete Label="Tipo documento" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                                 T="DocumentType"
                                 Placeholder="-- Seleccione  tipo documento --"
                                 SearchFunc="SearchFuncDocumentType"
                                 Value="selectedDocumentType"
                                 ValueChanged="ChangedDocumentType"
                                 ToStringFunc="@(e=> e==null?null : $"{e.Name}")">
                    <ItemTemplate Context="itemContext">
                        @itemContext.Name
                    </ItemTemplate>
                </MudAutocomplete>
                 
                <MudTextField Label="Nombres" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              @bind-Value="@CustomerDtoENT.FirstName"
                              For="@(() => CustomerDtoENT.FirstName)">
                </MudTextField>
                               
                <MudTextField Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              @bind-Value="@CustomerDtoENT.Email"
                              For="@(() => CustomerDtoENT.Email)">
                </MudTextField>

            </MudItem>

            <MudItem xs="6" sm="6">

                <MudTextField Label="Celular" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              @bind-Value="@CustomerDtoENT.phone"
                              For="@(() => CustomerDtoENT.phone)">

                </MudTextField>

                <MudTextField Label="Documento" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              Disabled="@DisabledDoc"
                              @bind-Value="@CustomerDtoENT.Document"
                              For="@(() => CustomerDtoENT.Document)">
                </MudTextField>
                 
                <MudTextField Label="Apellidos" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                              @bind-Value="@CustomerDtoENT.LastName"
                              For="@(() => CustomerDtoENT.LastName)">
                </MudTextField>
                               

                <MudAutocomplete Label="Género" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                                 T="EnumGenericDTO"
                                 Placeholder="-- Seleccione género --"
                                 SearchFunc="SearchFuncGender"
                                 Value="selectedGender"
                                 ValueChanged="ChangedGender"
                                 ToStringFunc="@(e=> e==null?null : $"{e.Name}")">
                    <ItemTemplate Context="itemContext">
                        @itemContext.Name
                    </ItemTemplate>
                </MudAutocomplete>

            </MudItem>

        </MudGrid>
        <MudGrid>
            <MudItem xs="9" Class="d-flex justify-end">

                <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="ReturnAction">
                    Regresar
                </MudButton>

                <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Save"
                           ButtonType="ButtonType.Submit">
                    @accion
                </MudButton>

            </MudItem>
        </MudGrid>
    </EditForm>

</MudContainer>